@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar shadow-sm">
        <NavMenu />
    </div>

    <main class="d-flex flex-column h-100">

        <AuthorizeView>

            @* Mostrara estos elementos si el usuario inicio sesion correctamente *@
            <Authorized>
                <div
                    class="top-row px-4 px-md-5 shadow-sm bg-white d-flex align-items-center justify-content-end border-bottom">
                    @* Mostrara el nombre de usuario + icono *@
                    <div class="d-flex align-items-center me-3 pe-3 border-end">
                        <i class="bi bi-person-circle text-primary fs-5 me-2"></i>
                        <span class="fw-bold text-dark">
                            @context.User.Identity?.Name
                        </span>
                    </div>

                    @* mostrara un boton de cerrar sesion *@
                    <a href="/logout"
                           class="text-secondary text-decoration-none fw-medium d-flex align-items-center btn-logout">
                        <i class="bi bi-box-arrow-right me-2 fs-5"></i>
                        Cerrar sesión
                    </a>
                    
                </div>
            </Authorized>

            @* Mostrara estos elementos si el usuario no inicio sesion *@
            <NotAuthorized>
                <div
                    class="top-row px-4 px-md-5 shadow-sm bg-white d-flex align-items-center justify-content-end border-bottom">
                    <a href="/login"
                           class="text-secondary text-decoration-none fw-medium transition-colors hover-primary d-flex align-items-center">
                        <i class="bi bi-box-arrow-in-right me-2 fs-5"></i>
                        Iniciar sesión
                    </a>
                </div>
            </NotAuthorized>

        </AuthorizeView>

        <article class="content flex-grow-1 p-4 p-md-5 overflow-auto">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" class="alert alert-danger shadow-lg border-0 rounded-top-4 mb-0 pb-3 pt-3">
    <div class="d-flex align-items-center justify-content-between container-fluid">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div>
                <span class="fw-bold d-block">Ha ocurrido un error inesperado.</span>
                <a href="" class="reload text-danger text-decoration-underline small">Recargar la aplicación</a>
            </div>
        </div>
        <a class="dismiss text-danger fs-5 text-decoration-none" title="Cerrar"><i class="bi bi-x-lg"></i></a>
    </div>
</div>