<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        @* <RouteView RouteData="routeData" DefaultLayout="typeof(Shared.MainLayout)" /> *@

        @* Nos permite proteger todas nuestras rutas y mostrar un mensaje *@
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Shared.MainLayout)">

            <NotAuthorized>

                <div class="container mt-5">
                    <div class="row justify-content-center">
                        <div class="col-md-6 text-center py-5 shadow-sm bg-white rounded-4 border">
                            <i class="bi bi-shield-lock-fill display-1 text-danger mb-4"></i>
                            <h2 class="fw-bold">Acceso Restringido</h2>
                            <p class="text-muted mb-4">
                                Lo sentimos, necesitas iniciar sesión o tener los permisos adecuados para ver esta
                                sección.
                            </p>
                            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                                <a href="/login" class="btn btn-primary btn-lg px-4 gap-3 rounded-pill shadow-sm">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Ir al Login
                                </a>
                                <a href="/" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                                    Volver al Inicio
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </NotAuthorized>

        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>

    <NotFound>
        <LayoutView Layout="typeof(Shared.MainLayout)">
            <div class="container text-center py-5">
                <i class="bi bi-patch-question display-1 text-secondary"></i>
                <h1 class="fw-bold mt-3">404 - No encontrado</h1>
                <p class="text-muted">La página que buscas no existe o ha sido movida.</p>
                <a href="/" class="btn btn-primary rounded-pill px-4 mt-3">Volver a mis notas</a>
            </div>
        </LayoutView>
    </NotFound>

</Router>